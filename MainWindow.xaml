<Window
    x:Class="AudioVisualizerOverlay.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AudioRadar"
    Width="250"
    Height="250"
    AllowsTransparency="True"
    Background="Transparent"
    Loaded="Window_Loaded"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None">

    <Viewbox Stretch="Uniform">
        <Grid Width="300" Height="300">
            <Ellipse
                Width="300"
                Height="300"
                Fill="#CC050505"
                Stroke="#00FF00"
                StrokeThickness="2" />

            <Ellipse
                Width="100"
                Height="100"
                Opacity="0.3"
                Stroke="#00FF00"
                StrokeThickness="1" />
            <Ellipse
                Width="200"
                Height="200"
                Opacity="0.3"
                Stroke="#00FF00"
                StrokeThickness="1" />
            <Line
                Opacity="0.5"
                Stroke="#00FF00"
                StrokeThickness="1"
                X1="50"
                X2="250"
                Y1="150"
                Y2="150" />
            <Line
                Opacity="0.5"
                Stroke="#00FF00"
                StrokeThickness="1"
                X1="150"
                X2="150"
                Y1="50"
                Y2="250" />

            <Ellipse
                Width="8"
                Height="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Fill="#00FF00" />

            <Canvas
                Name="RadarCanvas"
                Width="300"
                Height="300">
                <Ellipse
                    Name="SoundDot"
                    Canvas.Left="138"
                    Canvas.Top="138"
                    Width="24"
                    Height="24"
                    Fill="#FF0000"
                    Opacity="0.9">
                    <Ellipse.Effect>
                        <DropShadowEffect
                            BlurRadius="15"
                            ShadowDepth="0"
                            Color="Red" />
                    </Ellipse.Effect>
                </Ellipse>
            </Canvas>
        </Grid>
    </Viewbox>
</Window>